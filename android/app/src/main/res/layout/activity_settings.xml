<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <!-- ===== Top bar ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettingsBack"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ Back" />

        <TextView
            style="@style/CardTitle.Myvu"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Settings" />

        <Space
            android:layout_width="72dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== AI provider ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Card.Myvu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView style="@style/CardTitle.Myvu"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="AI provider" />

                    <TextView style="@style/Label.Myvu"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Who answers your questions. The key and model are remembered per provider, and stored on this device only — never in the app's source." />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/btnProviderGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnProviderClaude"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Claude" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnProviderOpenai"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="ChatGPT" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnProviderGemini"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Gemini" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnProviderLocal"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Local" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <!-- Hint and helper are set at runtime for the chosen provider. -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layApiKey"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="API key"
                        app:helperTextEnabled="true"
                        app:endIconMode="password_toggle">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtApiKey"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layModel"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Model"
                        app:helperTextEnabled="true">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtModel"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="text"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layAiEndpoint"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Chat Completions endpoint"
                        app:helperTextEnabled="true"
                        app:helperText="Full /v1/chat/completions URL; private-LAN HTTP or HTTPS">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtAiEndpoint"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textUri"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Speech to text ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Card.Myvu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView style="@style/CardTitle.Myvu"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Speech to text" />

                    <TextView style="@style/Label.Myvu"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Transcribes what you say into the glasses' microphone. Stored on this device only." />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/btnSttProviderGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSttGroq"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Groq" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSttLocal"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Local" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/laySttApiKey"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="STT API key"
                        app:helperTextEnabled="true"
                        app:endIconMode="password_toggle">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtSttApiKey"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/laySttEndpoint"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Transcriptions endpoint"
                        app:helperTextEnabled="true"
                        app:helperText="Full /v1/audio/transcriptions URL">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtSttEndpoint"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textUri"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/laySttModel"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="STT model"
                        app:helperTextEnabled="true">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtSttModel"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="text"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Text to speech ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Card.Myvu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView style="@style/CardTitle.Myvu"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Text to speech" />

                    <TextView style="@style/Label.Myvu"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Speaks answers through Android or an OpenAI-compatible HTTP speech service." />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/btnTtsProviderGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTtsSystem"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Device" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTtsHttp"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="HTTP API" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layTtsEndpoint"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Speech endpoint"
                        app:helperTextEnabled="true"
                        app:helperText="Full /v1/audio/speech URL; private-LAN HTTP or HTTPS">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtTtsEndpoint"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textUri"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layTtsApiKey"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="TTS API key"
                        app:helperTextEnabled="true"
                        app:helperText="Optional Bearer token"
                        app:endIconMode="password_toggle">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtTtsApiKey"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layTtsModel"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="TTS model"
                        app:helperTextEnabled="true"
                        app:helperText="Optional; omitted when blank">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtTtsModel"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="text"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layTtsVoice"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="TTS voice"
                        app:helperTextEnabled="true"
                        app:helperText="Optional; omitted when blank">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtTtsVoice"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="text"
                            android:importantForAutofill="no" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Notification mirroring ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Card.Myvu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView style="@style/CardTitle.Myvu"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Notification mirroring" />

                    <TextView style="@style/Label.Myvu"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Choose which apps may send notifications to the glasses. Nothing is mirrored until you pick some — notifications can carry one-time codes and private messages." />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickApps"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Choose apps" />

                    <TextView
                        android:id="@+id/txtAllowedSummary"
                        style="@style/Label.Myvu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="No apps selected" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Assistant behaviour ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Card.Myvu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView style="@style/CardTitle.Myvu"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Assistant system prompt" />

                    <TextView style="@style/Label.Myvu"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Shapes how the assistant replies. Answers are spoken aloud, so keep them short and free of markdown, lists and emoji. Applies to your next question — no reconnect needed." />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="System prompt">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/txtSystemPrompt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="5"
                            android:gravity="top|start"
                            android:inputType="textMultiLine|textCapSentences"
                            android:importantForAutofill="no" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetPrompt"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Reset to default" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
