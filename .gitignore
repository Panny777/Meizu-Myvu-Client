# Repo-wide ignores. Python-specific rules live in python/.gitignore.

# ---- Secrets & local machine config -- never commit ----
**/.env
**/local.properties
**/*.keystore
**/*.jks

# ---- Android / Gradle build output ----
android/build/
android/.gradle/
android/.kotlin/
android/app/build/
**/build/
*.apk
*.aab

# ---- Reverse-engineering artifacts ----
# The decompiled official app, packet captures and bug reports are deliberately
# kept OUTSIDE this repo (proprietary code / device data). Never add them.
apk_decompiled/
bugreport-*.zip
*.btsnoop
btcsnoop_*
BT_HCI_*

# ---- Runtime / capture dumps ----
*.log
*.wav
*.tsv
mic_capture.bin
scratch_*.png

# ---- Editor / OS ----
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
